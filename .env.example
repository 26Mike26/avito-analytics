# Скопируйте этот файл в .env и заполните, чтобы включить мульти-пользовательский режим (Supabase).
# Если переменные пустые — приложение работает в локальном режиме (демо в localStorage).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Адрес backend-прокси к Avito API (опционально). Если пустой — режим API недоступен,
# но demo и CSV-импорт работают.
VITE_AVITO_PROXY_URL=
